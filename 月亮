<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>小猫 · 正在</title>

<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;500&display=swap" rel="stylesheet">

<style>
:root{
  --bg-day:#e8eaee;
  --bg-night:#0f1116;
  --text-day:#1a1c20;
  --text-night:#e6e8ef;
  --accent:#8c82ff;
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:"Noto Serif SC",serif;
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  transition:background 1.2s ease, color 1.2s ease;
  overflow:hidden;
}

.container{
  text-align:center;
  max-width:600px;
  padding:40px;
}

h1{
  font-size:42px;
  font-weight:500;
  letter-spacing:6px;
  margin-bottom:24px;
  opacity:0.9;
}

.subtitle{
  font-size:14px;
  letter-spacing:3px;
  margin-bottom:60px;
  opacity:0.6;
}

.now{
  font-size:18px;
  line-height:2;
  margin-bottom:80px;
}

.now span{
  display:block;
  opacity:0.85;
}

.empty{
  height:120px; /* 刻意留白 */
}

.footer{
  font-size:12px;
  opacity:0.4;
  letter-spacing:2px;
}

/* 星点 */
.star{
  position:absolute;
  width:2px;
  height:2px;
  background:var(--accent);
  border-radius:50%;
  opacity:0.4;
  transition:transform 0.2s ease;
}
</style>
</head>

<body>

<div class="container">
  <h1>小猫</h1>
  <div class="subtitle">2006 · 02 · 07 · INF P</div>

  <div class="now">
    <span>我正在学习钢琴。</span>
    <span>我正在阅读。</span>
    <span>我正在思考结构。</span>
    <span>我正在试探河流。</span>
    <span>我正在校准自己。</span>
  </div>

  <div class="empty"></div>

  <div class="footer">
    不解释 · 不评判 · 只是存在
  </div>
</div>

<script>
const hour = new Date().getHours();
const body = document.body;

// 日夜切换
if(hour >= 22 || hour < 6){
  body.style.background = "var(--bg-night)";
  body.style.color = "var(--text-night)";
}else{
  body.style.background = "var(--bg-day)";
  body.style.color = "var(--text-day)";
}

// 创建星点
for(let i=0;i<40;i++){
  let star = document.createElement("div");
  star.className="star";
  star.style.left=Math.random()*100+"vw";
  star.style.top=Math.random()*100+"vh";
  document.body.appendChild(star);
}

// 轻微视差
document.addEventListener("mousemove",e=>{
  const stars = document.querySelectorAll(".star");
  stars.forEach(star=>{
    const x = (e.clientX/window.innerWidth - 0.5)*6;
    const y = (e.clientY/window.innerHeight - 0.5)*6;
    star.style.transform=`translate(${x}px,${y}px)`;
  });
});

// 窗口过大时文字缩小（尺度提醒）
window.addEventListener("resize",()=>{
  if(window.innerWidth > 1800){
    document.querySelector("h1").style.fontSize="34px";
  }
});
</script>

</body>
</html>
